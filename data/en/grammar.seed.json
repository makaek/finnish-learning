  "topics": [
    {
      "id": "to_be",
      "module": "verb",
      "order": 1,
      "level": 1,
      "title": "Глагол to be",
      "summary": "am / is / are — связка, которой в русском нет",
      "tags": ["tense"],
      "prereq": [],
      "rule_ids": ["to-be"],
      "needs_review": false,
      "theory": {
        "title": "Глагол to be (am / is / are)",
        "summary": "В английском «Я студент» — это «I am a student»: связка обязательна.",
        "body_ru": "Русское предложение «Я студент» по-английски всегда с глаголом: *I am a student*. Формы зависят от лица: *I am*, *he / she / it is*, *you / we / they are*. В разговорной речи — сокращения: *I'm, he's, you're, we're, they're*. Без *to be* предложение неполное: не *She happy*, а *She is happy*.",
        "examples": [
          { "fi": "I am a teacher.", "ru": "Я учитель." },
          { "fi": "She is happy.", "ru": "Она счастлива." },
          { "fi": "We are at home.", "ru": "Мы дома." }
        ],
        "paradigm": {
          "caption": "be · настоящее время",
          "rows": [
            { "l": "I", "f": "{am}" },
            { "l": "you", "f": "{are}" },
            { "l": "he / she / it", "f": "{is}" },
            { "l": "we", "f": "{are}" },
            { "l": "they", "f": "{are}" }
          ],
          "key": [
            { "hl": "main", "label": "форма to be" }
          ]
        },
        "note_ru": "У *I* всегда *am*. У *he / she / it* — *is*. У *you / we / they* — *are*. Связку нельзя опустить: *She is a doctor*, не *She a doctor*."
      }
    },
    {
      "id": "articles",
      "module": "noun",
      "order": 2,
      "level": 1,
      "title": "Артикли a / an / the",
      "summary": "a / an перед исчисляемым; the — про известное; вода/кофе — без a",
      "tags": ["article"],
      "prereq": [],
      "rule_ids": ["articles"],
      "needs_review": false,
      "theory": {
        "title": "Артикли a / an / the",
        "summary": "Перед исчисляемым существительным в ед. числе нужен артикль.",
        "body_ru": "*a* ставится перед согласным звуком: *a dog, a book*. *an* — перед гласным: *an apple, an hour*. *the* — про конкретный, уже известный предмет: *the door is open*. Неисчисляемые (*water, coffee, bread, milk, money*) употребляются без *a*: *I drink coffee*, а не *a coffee*. Перед профессией нужен артикль: *I am a student*.",
        "examples": [
          { "fi": "I have a dog.", "ru": "У меня есть собака." },
          { "fi": "She eats an apple.", "ru": "Она ест яблоко." },
          { "fi": "I drink water.", "ru": "Я пью воду." }
        ],
        "note_ru": "Выбор *a / an* — по звуку: *a university* (звук «ю»), но *an hour* (h не читается). Неисчисляемое — без *a*: *bread, water, money*."
      }
    },
    {
      "id": "present_simple",
      "module": "verb",
      "order": 3,
      "level": 2,
      "title": "Present Simple",
      "summary": "I / you / we / they + базовая форма глагола; порядок SVO",
      "tags": ["tense", "syntax"],
      "prereq": ["to_be"],
      "rule_ids": ["word-order"],
      "needs_review": false,
      "theory": {
        "title": "Present Simple (настоящее простое)",
        "summary": "Регулярные действия: глагол в базовой форме, без -ing и без to be.",
        "body_ru": "Для *I / you / we / they* глагол стоит в базовой форме: *I live, you work, we read, they speak*. Это время для привычек и фактов: *I work every day*. Важно: глагол сам по себе — не нужен ни *am*, ни *-ing*: не *I am work*, не *I working*, а *I work*. Порядок слов жёсткий: подлежащее — глагол — дополнение (*I read books*).",
        "examples": [
          { "fi": "I live in a big house.", "ru": "Я живу в большом доме." },
          { "fi": "We read books.", "ru": "Мы читаем книги." },
          { "fi": "They speak English.", "ru": "Они говорят по-английски." }
        ],
        "note_ru": "В Present Simple не ставят *am / is / are* перед смысловым глаголом: *I work*, а не *I am work*. Форма *-ing* — это другое время (Present Continuous)."
      }
    },
    {
      "id": "possessives",
      "module": "noun",
      "order": 4,
      "level": 2,
      "title": "Притяжательные my / your / 's",
      "summary": "my, your, his, her, our, their + 's для принадлежности (Tom's)",
      "tags": ["pron"],
      "prereq": [],
      "rule_ids": [],
      "needs_review": false,
      "theory": {
        "title": "Притяжательные: my / your и 's",
        "summary": "«Чей?» — притяжательное слово или окончание 's.",
        "body_ru": "Притяжательные слова: *my* (мой), *your* (твой/ваш), *his* (его), *her* (её), *our* (наш), *their* (их). Они стоят перед существительным: *my mother, her dog, our house*. Не путайте с подлежащим: «моя» — *my*, а не *I*. Принадлежность человеку показывают окончанием *'s*: *Tom's sister* (сестра Тома), *my father's car*.",
        "examples": [
          { "fi": "This is my book.", "ru": "Это моя книга." },
          { "fi": "Her name is Anna.", "ru": "Её зовут Анна." },
          { "fi": "This is Tom's sister.", "ru": "Это сестра Тома." }
        ],
        "note_ru": "«Моя книга» — *my book*, не *I book* и не *me book*. Принадлежность — через *'s*: *Tom's sister*, а не *the sister of Tom*."
      }
    },
    {
      "id": "third_person_s",
      "module": "verb",
      "order": 5,
      "level": 3,
      "title": "-s в 3-м лице",
      "summary": "he / she / it + глагол с -s/-es; have -> has, go -> goes",
      "tags": ["tense"],
      "prereq": ["present_simple"],
      "rule_ids": ["third-person-s"],
      "needs_review": false,
      "theory": {
        "title": "-s в 3-м лице (he / she / it)",
        "summary": "В Present Simple к глаголу he/she/it добавляется -s.",
        "body_ru": "У *I / you / we / they* глагол без окончания, но у *he / she / it* добавляется *-s*: *I like — he likes*, *we live — she lives*. После *-o, -s, -sh, -ch, -x* пишут *-es*: *go — goes*, *watch — watches*. Особые формы: *have — has*. Это окончание — частая ошибка: легко забыть *-s* в 3-м лице.",
        "examples": [
          { "fi": "He likes bread.", "ru": "Он любит хлеб." },
          { "fi": "She goes home.", "ru": "Она идёт домой." },
          { "fi": "She has a cat.", "ru": "У неё есть кошка." }
        ],
        "paradigm": {
          "caption": "live · настоящее время",
          "rows": [
            { "l": "I", "f": "live" },
            { "l": "you", "f": "live" },
            { "l": "he / she / it", "f": "live{s}" },
            { "l": "we", "f": "live" },
            { "l": "they", "f": "live" }
          ],
          "key": [
            { "hl": "main", "label": "окончание -s (3-е лицо)" }
          ]
        },
        "note_ru": "*-s* только у *he / she / it*. У остальных лиц глагол без окончания: *they live*, но *she lives*. Особые: *have -> has*, *go -> goes*, *do -> does*."
      }
    },
    {
      "id": "plurals",
      "module": "noun",
      "order": 6,
      "level": 3,
      "title": "Множественное число",
      "summary": "-s / -es; man -> men, child -> children; вода — без мн. числа",
      "tags": ["plural"],
      "prereq": ["articles"],
      "rule_ids": ["plurals"],
      "needs_review": false,
      "theory": {
        "title": "Множественное число (-s / -es)",
        "summary": "Обычно -s; после -s/-sh/-ch/-x — -es; есть особые формы.",
        "body_ru": "Множественное число обычно образуется окончанием *-s*: *one dog -> two dogs, three apples*. После *-s, -sh, -ch, -x* добавляют *-es*: *box -> boxes*. Особые формы надо запомнить: *man -> men, woman -> women, child -> children, person -> people*. После числа больше одного — всегда множественное и без *a*: *two brothers*, не *a two brothers*. Неисчисляемые (*water, bread, money*) множественного числа не имеют.",
        "examples": [
          { "fi": "two brothers", "ru": "два брата" },
          { "fi": "five days", "ru": "пять дней" },
          { "fi": "three children", "ru": "трое детей" }
        ],
        "note_ru": "С числом артикль *a* не нужен: *two dogs*, не *a two dogs*. Особые формы: *children, men, women, people* — у них нет второго *-s*."
      }
    },
    {
      "id": "this_these",
      "module": "noun",
      "order": 7,
      "level": 3,
      "title": "this / that / these / those",
      "summary": "this/that — ед. число, these/those — мн.; сказуемое согласуется",
      "tags": ["pron", "plural"],
      "prereq": ["plurals"],
      "rule_ids": ["demonstratives"],
      "needs_review": false,
      "theory": {
        "title": "Указательные: this / that / these / those",
        "summary": "this/that для одного, these/those для многих.",
        "body_ru": "*this* (этот, рядом) и *that* (тот, дальше) — для единственного числа. Во множественном они меняются: *this -> these*, *that -> those*: *this apple -> these apples*. Сказуемое согласуется в числе: *This apple is tasty*, но *These apples are tasty* (не *is*).",
        "examples": [
          { "fi": "This is my friend.", "ru": "Это мой друг." },
          { "fi": "These apples are tasty.", "ru": "Эти яблоки вкусные." },
          { "fi": "Those dogs are big.", "ru": "Те собаки большие." }
        ],
        "note_ru": "Множественное — *these / those*, и глагол тоже во мн. числе: *These books are new* (не *is*)."
      }
    },
    {
      "id": "do_questions",
      "module": "syntax",
      "order": 8,
      "level": 4,
      "title": "Вопрос и отрицание (do / does)",
      "summary": "Do / Does …? и don't / doesn't + базовая форма",
      "tags": ["syntax"],
      "prereq": ["present_simple", "third_person_s"],
      "rule_ids": ["do-support", "word-order"],
      "needs_review": false,
      "theory": {
        "title": "Вопросы и отрицания через do / does",
        "summary": "В Present Simple вопрос и отрицание строятся с do/does.",
        "body_ru": "Со смысловым глаголом вопрос и отрицание требуют вспомогательного *do*: *Do you speak English?*, *I don't drink tea*. В 3-м лице берётся *does*, и тогда *-s* переходит на него, а сам глагол остаётся в базовой форме: *Does he like tea?*, *She doesn't drink coffee* (не *doesn't drinks*). Нельзя строить вопрос простой перестановкой: не *You speak English?*, а *Do you speak English?*",
        "examples": [
          { "fi": "Do you speak English?", "ru": "Ты говоришь по-английски?" },
          { "fi": "He doesn't like coffee.", "ru": "Он не любит кофе." },
          { "fi": "Where do you live?", "ru": "Где ты живёшь?" }
        ],
        "note_ru": "После *do / does / don't / doesn't* глагол всегда в базовой форме: *Does she like…?*, *He doesn't like…*. *-s* уже «забрал» *does*."
      }
    },
    {
      "id": "can",
      "module": "verb",
      "order": 9,
      "level": 5,
      "title": "Модальный глагол can",
      "summary": "can + базовая форма; can't; Can you …? без do",
      "tags": ["modal"],
      "prereq": ["present_simple"],
      "rule_ids": [],
      "needs_review": false,
      "theory": {
        "title": "Модальный глагол can (уметь / мочь)",
        "summary": "can + базовый глагол, без to и без -s.",
        "body_ru": "*can* выражает умение и возможность: *I can swim, she can cook*. После *can* глагол стоит в базовой форме — без *to* и без *-s*: *can speak*, не *can to speak* и не *can speaks*. Сам *can* не меняется по лицам: *he can* (не *cans*). Отрицание — *can't* (= cannot); вопрос — простой перестановкой, без *do*: *Can you help?*",
        "examples": [
          { "fi": "I can speak English.", "ru": "Я умею говорить по-английски." },
          { "fi": "She can't come.", "ru": "Она не может прийти." },
          { "fi": "Can you help me?", "ru": "Ты можешь мне помочь?" }
        ],
        "note_ru": "После *can* — базовая форма: *can cook*, не *can cooks*. С *can* не нужен *do*: вопрос *Can you…?*, отрицание *can't*."
      }
    },
    {
      "id": "there_is_are",
      "module": "syntax",
      "order": 10,
      "level": 5,
      "title": "Оборот there is / there are",
      "summary": "«где-то есть …»: there is (ед.) / there are (мн.)",
      "tags": ["syntax"],
      "prereq": ["to_be"],
      "rule_ids": ["there-is"],
      "needs_review": false,
      "theory": {
        "title": "Оборот there is / there are",
        "summary": "«Где-то есть что-то» — через there is / there are.",
        "body_ru": "Чтобы сказать, что где-то что-то есть, начинают с *there is* (для ед. числа) или *there are* (для мн.): *There is a table in the room*, *There are seven days in a week*. Нельзя начинать с обстоятельства места: не *In the room is a table*. После *there is* у исчисляемого нужен артикль *a*: *There is a window*.",
        "examples": [
          { "fi": "There is a table in the room.", "ru": "В комнате есть стол." },
          { "fi": "There are two parks in the city.", "ru": "В городе два парка." },
          { "fi": "There is a book on the table.", "ru": "На столе книга." }
        ],
        "note_ru": "Ед. число — *There is a …*; мн. число — *There are … (s)*. Оборот всегда начинается с *there*, а не с места."
      }
    },
    {
      "id": "past_simple",
      "module": "verb",
      "order": 11,
      "level": 6,
      "title": "Past Simple",
      "summary": "правильные -ed; was/were, went, had, bought",
      "tags": ["tense"],
      "prereq": ["present_simple"],
      "rule_ids": [],
      "needs_review": false,
      "theory": {
        "title": "Past Simple (прошедшее простое)",
        "summary": "Правильные глаголы -ed; неправильные надо запомнить.",
        "body_ru": "Прошедшее правильных глаголов — с окончанием *-ed*: *work -> worked, open -> opened*. Многие частые глаголы неправильные — их форму учат: *be -> was / were, go -> went, have -> had, see -> saw, buy -> bought*. Форма прошедшего одинакова для всех лиц (*I worked, she worked*), кроме *to be*: *I / he / she / it was*, *you / we / they were*.",
        "examples": [
          { "fi": "I worked yesterday.", "ru": "Вчера я работал." },
          { "fi": "We went to the shop.", "ru": "Мы ходили в магазин." },
          { "fi": "She bought a shirt.", "ru": "Она купила рубашку." }
        ],
        "paradigm": {
          "caption": "be · прошедшее время",
          "rows": [
            { "l": "I", "f": "{was}" },
            { "l": "you", "f": "{were}" },
            { "l": "he / she / it", "f": "{was}" },
            { "l": "we", "f": "{were}" },
            { "l": "they", "f": "{were}" }
          ],
          "key": [
            { "hl": "main", "label": "форма прошедшего to be" }
          ]
        },
        "note_ru": "*was* — для I / he / she / it; *were* — для you / we / they. Неправильные глаголы (*go -> went, buy -> bought*) не берут *-ed*."
      }
    },
    {
      "id": "present_continuous",
      "module": "verb",
      "order": 12,
      "level": 7,
      "title": "Present Continuous",
      "summary": "am/is/are + глагол с -ing: действие прямо сейчас",
      "tags": ["tense"],
      "prereq": ["present_simple", "to_be"],
      "rule_ids": [],
      "needs_review": false,
      "theory": {
        "title": "Present Continuous (настоящее длительное)",
        "summary": "Действие происходит в момент речи: be + V-ing.",
        "body_ru": "Когда действие происходит прямо сейчас, используют *to be + глагол с -ing*: *I am reading now*, *She is cooking*, *They are playing*. Нужны обе части: и *am / is / are*, и *-ing* — не *She cooking* и не *She is cook*. Слова-подсказки: *now, right now, at the moment*. Сравните: *I work every day* (привычка, Present Simple) — но *I am working now* (прямо сейчас).",
        "examples": [
          { "fi": "I am reading now.", "ru": "Я сейчас читаю." },
          { "fi": "She is cooking.", "ru": "Она готовит." },
          { "fi": "They are playing.", "ru": "Они играют." }
        ],
        "paradigm": {
          "caption": "read · сейчас (be + V-ing)",
          "rows": [
            { "l": "I", "f": "{am} read{ing}" },
            { "l": "you", "f": "{are} read{ing}" },
            { "l": "he / she / it", "f": "{is} read{ing}" },
            { "l": "we", "f": "{are} read{ing}" },
            { "l": "they", "f": "{are} read{ing}" }
          ],
          "key": [
            { "hl": "main", "label": "be + окончание -ing" }
          ]
        },
        "note_ru": "Обе части обязательны: *is cooking*, не *cooking* и не *is cook*. Для действия сейчас — Continuous (*is cooking*), а не Present Simple (*cooks*)."
      }
    }
  ],


  "items": [
    { "id": "tobe-s1-w1", "topic": "to_be", "set": 1, "stage": "warmup", "type": "choose_form",
      "prompt_fi": "I ___ a teacher.", "hint_ru": "(я)",
      "options": [
        { "fi": "am" },
        { "fi": "is", "why_ru": "*is* — для he/she/it. У *I* всегда *am*." },
        { "fi": "are", "why_ru": "*are* — для you/we/they. У *I* — *am*." }
      ],
      "answer": "am", "ok_ru": "Верно: у *I* всегда форма *am* — *I am a teacher*." },

    { "id": "tobe-s1-d1", "topic": "to_be", "set": 1, "stage": "drill", "type": "fill_table",
      "prompt_fi": "be · настоящее время", "prompt_ru": "Поставьте нужную форму to be.",
      "review_ru": "формы to be",
      "cells": [
        { "l": "I", "canonical": "{am}", "accepted": ["am"] },
        { "l": "you", "canonical": "{are}", "accepted": ["are"] },
        { "l": "he", "canonical": "{is}", "accepted": ["is"] },
        { "l": "we", "canonical": "{are}", "accepted": ["are"] },
        { "l": "they", "canonical": "{are}", "accepted": ["are"] }
      ],
      "summary_ru": "*am* — I; *is* — he/she/it; *are* — you/we/they." },

    { "id": "tobe-s2-w1", "topic": "to_be", "set": 2, "stage": "warmup", "type": "choose_form",
      "prompt_fi": "They ___ students.", "hint_ru": "(они)",
      "options": [
        { "fi": "are" },
        { "fi": "is", "why_ru": "*is* — для одного (he/she/it). Для *they* — *are*." },
        { "fi": "am", "why_ru": "*am* — только для *I*." }
      ],
      "answer": "are", "ok_ru": "Да: *They are students* — у *they* форма *are*." },

    { "id": "tobe-s2-d1", "topic": "to_be", "set": 2, "stage": "drill", "type": "produce_form",
      "prompt_fi": "She ___ at home.", "prompt_ru": "Она дома.", "hint_ru": "форма to be",
      "canonical": "{is}", "accepted": ["is"],
      "wrong": [
        { "match": "are", "ru": "У *she* — *is*, не *are*: *She is at home*." },
