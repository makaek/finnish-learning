    {"id":"a5","fi":"kylmä","ru":"холодный","pos":"adj","level":5,"part_sg":"kylmää","notes":"Mass-subject predicative: 'Vesi on kylmää' = Вода холодная. 'Sää on kylmä' (countable-ish weather)."},
    {"id":"a6","fi":"kuuma","ru":"горячий","pos":"adj","level":5,"part_sg":"kuumaa","notes":"For hot weather often 'kuuma'; for very warm/cosy use lämmin."},
    {"id":"a7","fi":"lämmin","ru":"тёплый","pos":"adj","level":5,"gen_sg":"lämpimän","part_sg":"lämmintä","notes":"IRREGULAR -min adj, stem lämpimä-: gen lämpimän, part lämmintä. 'Kahvi on lämmintä' (mass, partitive)."},
    {"id":"a8","fi":"kaunis","ru":"красивый","pos":"adj","level":5,"gen_sg":"kauniin","part_sg":"kaunista","notes":"Stem kaunii-: gen kauniin, part kaunista. 'kaunis ilma' = хорошая/красивая погода."},
    {"id":"a9","fi":"vaikea","ru":"трудный / сложный","pos":"adj","level":5,"part_sg":"vaikeaa","notes":"'Suomi on vaikeaa' (language as mass -> partitive) vs 'Tehtävä on vaikea' (countable -> nominative)."},
    {"id":"a10","fi":"helppo","ru":"лёгкий / простой","pos":"adj","level":5,"gen_sg":"helpon","part_sg":"helppoa","notes":"Gradation pp->p: helPPo but helPon."},
    {"id":"a11","fi":"kallis","ru":"дорогой","pos":"adj","level":4,"gen_sg":"kalliin","part_sg":"kallista","notes":"Stem kallii-: gen kalliin, part kallista. 'Auto on kallis' = Машина дорогая."},
    {"id":"a12","fi":"halpa","ru":"дешёвый","pos":"adj","level":4,"gen_sg":"halvan","part_sg":"halpaa","notes":"Gradation p->v: halPa but halVan."}
