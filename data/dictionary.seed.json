  "function_words": [
    {"id":"f1","fi":"ja","ru":"и","pos":"conj","level":1},
    {"id":"f2","fi":"mutta","ru":"но","pos":"conj","level":2},
    {"id":"f3","fi":"nyt","ru":"сейчас","pos":"adv","level":2},
    {"id":"f4","fi":"tänään","ru":"сегодня","pos":"adv","level":2},
    {"id":"f5","fi":"huomenna","ru":"завтра","pos":"adv","level":2},
    {"id":"f6","fi":"ei","ru":"не / нет","pos":"neg_verb","level":1,"forms":{"minä":"en","sinä":"et","hän":"ei","me":"emme","te":"ette","he":"eivät"},"notes":"Negation verb + connegative: 'En puhu suomea' = Я не говорю по-фински."},
    {"id":"f7","fi":"eilen","ru":"вчера","pos":"adv","level":2,"notes":"Indeclinable time adverb, pairs with past tense: 'Eilen olin kotona' = Вчера я был дома."},

    {"id":"f8","fi":"missä","ru":"где","pos":"adv","level":3,"notes":"Inessive question word (где?): 'Missä sinä asut?' = Где ты живёшь? Direction 'куда?' is mihin, origin 'откуда?' is mistä.","needs_review":false},
    {"id":"f9","fi":"milloin","ru":"когда","pos":"adv","level":3,"notes":"'Milloin tulet?' = Когда ты придёшь? Synonym koska (also a conjunction 'потому что').","needs_review":false},
    {"id":"f10","fi":"miksi","ru":"почему","pos":"adv","level":3,"notes":"'Miksi?' = Почему? Answer often begins with koska ('потому что').","needs_review":false},
    {"id":"f11","fi":"kuinka","ru":"как / насколько","pos":"adv","level":3,"notes":"'Kuinka voit?' = Как дела? 'Kuinka paljon?' = Сколько? Synonym miten.","needs_review":false},
    {"id":"f12","fi":"paljonko","ru":"сколько","pos":"adv","level":3,"notes":"Price/quantity: 'Paljonko se maksaa?' = Сколько это стоит? From paljon + -ko.","needs_review":false},
    {"id":"f13","fi":"miten","ru":"как (каким образом)","pos":"adv","level":3,"notes":"Manner: 'Miten sanot tämän suomeksi?' = Как это сказать по-фински? Overlaps with kuinka.","needs_review":false},

    {"id":"f14","fi":"nolla","ru":"ноль","pos":"num","level":3,"needs_review":false},
    {"id":"f15","fi":"yksi","ru":"один","pos":"num","level":3,"notes":"'yksi kahvi' or just 'yksi'. Partitive yhtä; gen yhden.","needs_review":false},
    {"id":"f16","fi":"kaksi","ru":"два","pos":"num","level":3,"notes":"After 2+ the counted noun is PARTITIVE SINGULAR: 'kaksi euroa', 'kaksi kahvia'. Part kahta, gen kahden.","needs_review":false},
    {"id":"f17","fi":"kolme","ru":"три","pos":"num","level":3,"notes":"'kolme euroa' (partitive sg after number).","needs_review":false},
    {"id":"f18","fi":"neljä","ru":"четыре","pos":"num","level":3,"needs_review":false},
    {"id":"f19","fi":"viisi","ru":"пять","pos":"num","level":3,"notes":"'viisi euroa' = пять евро. Part viittä, gen viiden.","needs_review":false},
    {"id":"f20","fi":"kuusi","ru":"шесть","pos":"num","level":3,"notes":"Also means 'ель' (spruce) as a noun homonym.","needs_review":false},
    {"id":"f21","fi":"seitsemän","ru":"семь","pos":"num","level":3,"needs_review":false},
    {"id":"f22","fi":"kahdeksan","ru":"восемь","pos":"num","level":3,"needs_review":false},
    {"id":"f23","fi":"yhdeksän","ru":"девять","pos":"num","level":3,"needs_review":false},
    {"id":"f24","fi":"kymmenen","ru":"десять","pos":"num","level":3,"notes":"Part kymmentä. Used in tens: kaksikymmentä = 20.","needs_review":false},
    {"id":"f25","fi":"kaksikymmentä","ru":"двадцать","pos":"num","level":4,"notes":"kaksi + kymmentä (partitive). Pattern: kolmekymmentä = 30 etc.","needs_review":false},
    {"id":"f26","fi":"sata","ru":"сто","pos":"num","level":4,"notes":"'sata euroa' = сто евро. Part sataa, gen sadan.","needs_review":false},

    {"id":"f27","fi":"että","ru":"что (союз)","pos":"conj","level":5,"notes":"Subordinating 'что': 'Tiedän, että hän tulee' = Я знаю, что он придёт. Note comma before että.","needs_review":false},
    {"id":"f28","fi":"koska","ru":"потому что","pos":"conj","level":5,"notes":"Cause: 'En tule, koska olen kipeä' (упрощённо). Answers miksi?","needs_review":false},
    {"id":"f29","fi":"kun","ru":"когда (союз)","pos":"conj","level":5,"notes":"Temporal subordinator (не вопрос): 'Kun olen kotona, luen' = Когда я дома, я читаю. Question 'когда?' is milloin.","needs_review":false},
    {"id":"f30","fi":"jos","ru":"если","pos":"conj","level":5,"notes":"Condition: 'Jos sataa, jään kotiin' (упрощённо). 'Jos haluat, voit tulla' = Если хочешь, можешь прийти.","needs_review":false},

    {"id":"f31","fi":"hei","ru":"привет","pos":"interj","level":3,"notes":"Informal greeting. Also 'moi', 'terve'. Formal: 'Hyvää päivää'.","needs_review":false},
    {"id":"f32","fi":"kiitos","ru":"спасибо","pos":"interj","level":3,"notes":"'Kiitos!' = Спасибо! 'Ei kiitos' = Нет, спасибо.","needs_review":false},
    {"id":"f33","fi":"anteeksi","ru":"извините","pos":"interj","level":3,"notes":"'Anteeksi!' = Извините! Also to get attention.","needs_review":false},
    {"id":"f34","fi":"kyllä","ru":"да","pos":"interj","level":3,"notes":"'Kyllä' = Да (эмфатическое/в ответ на вопрос с -ko). Opposite ei = нет.","needs_review":false}
