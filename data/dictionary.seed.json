    {"id":"n13","fi":"ystävä","ru":"друг","pos":"noun","gen_sg":"ystävän","part_sg":"ystävää","iness_sg":"ystävässä","illat_sg":"ystävään","notes":""},
    {"id":"n14","fi":"ruoka","ru":"еда","pos":"noun","gen_sg":"ruoan","part_sg":"ruokaa","iness_sg":"ruoassa","illat_sg":"ruokaan","notes":"Gradation k->(zero) in weak forms (ruoan, also spelled ruuan)."}
