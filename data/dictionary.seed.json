{
  "_meta": {
    "purpose": "Seed dictionary for a Finnish-for-Russian-speakers trainer. This is a SEED: ~35 high-frequency A1 entries, hand-verified. The `finnish-linguist` subagent expands and re-verifies it.",
    "why_the_extra_fields": "Russian->Finnish translation cannot work on dictionary forms alone. Finnish inflects nouns through ~15 cases (with consonant gradation) and conjugates verbs by person. The sentence exercise ('Я иду на работу' -> 'Menen töihin') needs these inflected forms, so each entry carries the forms the app actually has to produce or accept.",
    "schema": {
      "noun": ["id","fi","ru","pos","level","gen_sg","part_sg","iness_sg (in/at)","illat_sg (into/to)","notes"],
      "verb": ["id","fi","ru","pos","level","verb_type","present (6 persons)","past_1sg","past_3sg","conneg (form used after the negation verb ei)","notes"]
    },
    "negation_note": "Finnish negation uses a conjugating verb ei (en, et, ei, emme, ette, eivät) + the connegative form. 'I don't go' = 'En mene'. Store `conneg` so the app can build and grade negatives.",
    "level": "A1 unless noted"
  },

