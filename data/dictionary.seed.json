{
  "_meta": {
    "purpose": "Seed dictionary for a Finnish-for-Russian-speakers trainer. This is a SEED: ~35 high-frequency A1 entries, hand-verified. The `finnish-linguist` subagent expands and re-verifies it.",
    "why_the_extra_fields": "Russian->Finnish translation cannot work on dictionary forms alone. Finnish inflects nouns through ~15 cases (with consonant gradation) and conjugates verbs by person. The sentence exercise ('Я иду на работу' -> 'Menen töihin') needs these inflected forms, so each entry carries the forms the app actually has to produce or accept.",
    "schema": {
      "noun": ["id","fi","ru","pos","level","gen_sg","part_sg","iness_sg (in/at)","illat_sg (into/to)","notes"],
      "verb": ["id","fi","ru","pos","level","verb_type","present (6 persons)","past_1sg","past_3sg","conneg (form used after the negation verb ei)","notes"]
    },
    "negation_note": "Finnish negation uses a conjugating verb ei (en, et, ei, emme, ette, eivät) + the connegative form. 'I don't go' = 'En mene'. Store `conneg` so the app can build and grade negatives.",
    "level": "A1 unless noted"
  },

  "pronouns": [
    {"id":"p1","fi":"minä","ru":"я","pos":"pronoun","gen":"minun","part":"minua"},
    {"id":"p2","fi":"sinä","ru":"ты","pos":"pronoun","gen":"sinun","part":"sinua"},
    {"id":"p3","fi":"hän","ru":"он / она","pos":"pronoun","gen":"hänen","part":"häntä"},
    {"id":"p4","fi":"me","ru":"мы","pos":"pronoun","gen":"meidän","part":"meitä"},
    {"id":"p5","fi":"te","ru":"вы","pos":"pronoun","gen":"teidän","part":"teitä"},
    {"id":"p6","fi":"he","ru":"они","pos":"pronoun","gen":"heidän","part":"heitä"}
  ],

  "verbs": [
    {"id":"v1","fi":"olla","ru":"быть","pos":"verb","verb_type":1,
      "present":{"minä":"olen","sinä":"olet","hän":"on","me":"olemme","te":"olette","he":"ovat"},
      "past_1sg":"olin","past_3sg":"oli","conneg":"ole",
      "notes":"Existence/identity. 'Minä olen opiskelija' = Я студент. Subject pronoun is often dropped: 'Olen...'"},
    {"id":"v2","fi":"mennä","ru":"идти / ехать (туда)","pos":"verb","verb_type":3,
      "present":{"minä":"menen","sinä":"menet","hän":"menee","me":"menemme","te":"menette","he":"menevät"},
      "past_1sg":"menin","past_3sg":"meni","conneg":"mene",
      "notes":"Direction TO uses illative or idiom: 'Menen töihin' (go to work), 'Menen kotiin' (go home)."},
    {"id":"v3","fi":"syödä","ru":"есть / кушать","pos":"verb","verb_type":2,
      "present":{"minä":"syön","sinä":"syöt","hän":"syö","me":"syömme","te":"syötte","he":"syövät"},
      "past_1sg":"söin","past_3sg":"söi","conneg":"syö",
      "notes":"Object usually PARTITIVE: 'Syön leipää', 'Söin lettuja' (Я ел блины)."},
    {"id":"v4","fi":"juoda","ru":"пить","pos":"verb","verb_type":2,
      "present":{"minä":"juon","sinä":"juot","hän":"juo","me":"juomme","te":"juotte","he":"juovat"},
      "past_1sg":"join","past_3sg":"joi","conneg":"juo",
      "notes":"Partitive object: 'Juon kahvia' (Я пью кофе)."},
    {"id":"v5","fi":"haluta","ru":"хотеть","pos":"verb","verb_type":4,
      "present":{"minä":"haluan","sinä":"haluat","hän":"haluaa","me":"haluamme","te":"haluatte","he":"haluavat"},
      "past_1sg":"halusin","past_3sg":"halusi","conneg":"halua",
      "notes":"Often + infinitive: 'Haluan syödä' (Я хочу есть)."},
    {"id":"v6","fi":"puhua","ru":"говорить","pos":"verb","verb_type":1,
      "present":{"minä":"puhun","sinä":"puhut","hän":"puhuu","me":"puhumme","te":"puhutte","he":"puhuvat"},
      "past_1sg":"puhuin","past_3sg":"puhui","conneg":"puhu",
      "notes":"'Puhun suomea' (Я говорю по-фински) — language in partitive."},
    {"id":"v7","fi":"asua","ru":"жить (проживать)","pos":"verb","verb_type":1,
      "present":{"minä":"asun","sinä":"asut","hän":"asuu","me":"asumme","te":"asutte","he":"asuvat"},
      "past_1sg":"asuin","past_3sg":"asui","conneg":"asu",
      "notes":"Place in inessive: 'Asun Helsingissä' (Я живу в Хельсинки)."},
    {"id":"v8","fi":"ostaa","ru":"покупать","pos":"verb","verb_type":1,
      "present":{"minä":"ostan","sinä":"ostat","hän":"ostaa","me":"ostamme","te":"ostatte","he":"ostavat"},
      "past_1sg":"ostin","past_3sg":"osti","conneg":"osta",
      "notes":""},
    {"id":"v9","fi":"lukea","ru":"читать","pos":"verb","verb_type":1,
      "present":{"minä":"luen","sinä":"luet","hän":"lukee","me":"luemme","te":"luette","he":"lukevat"},
      "past_1sg":"luin","past_3sg":"luki","conneg":"lue",
      "notes":"Gradation k->(zero): luen but luKee."},
    {"id":"v10","fi":"tehdä","ru":"делать","pos":"verb","verb_type":2,
      "present":{"minä":"teen","sinä":"teet","hän":"tekee","me":"teemme","te":"teette","he":"tekevät"},
      "past_1sg":"tein","past_3sg":"teki","conneg":"tee",
      "notes":"Irregular-ish: tee- / teke-."}
  ],

  "nouns": [
