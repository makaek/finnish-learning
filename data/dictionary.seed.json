    {"id":"n8","fi":"kahvi","ru":"кофе","pos":"noun","gen_sg":"kahvin","part_sg":"kahvia","iness_sg":"kahvissa","illat_sg":"kahviin","notes":"Drinking it: partitive 'kahvia'."},
    {"id":"n9","fi":"leipä","ru":"хлеб","pos":"noun","gen_sg":"leivän","part_sg":"leipää","iness_sg":"leivässä","illat_sg":"leipään","notes":"Gradation p->v (leivän)."},
    {"id":"n10","fi":"lettu","ru":"блин","pos":"noun","gen_sg":"letun","part_sg":"lettua","part_pl":"lettuja","iness_sg":"letussa","illat_sg":"lettuun","notes":"'Я ел блины' = Söin lettuja (partitive plural). Synonyms: ohukainen, pannukakku."},
    {"id":"n11","fi":"vesi","ru":"вода","pos":"noun","gen_sg":"veden","part_sg":"vettä","iness_sg":"vedessä","illat_sg":"veteen","notes":"Irregular -si type."},
